# Local TurtleBot 4 runtime configuration template.
# Copy to `.env` or export values in your shell. Do not commit real secrets.

# Robot network / SSH
ROBOT_IP="127.0.0.1"
ROBOT_SSH_TARGET="robot@robot-hostname"
ROS_DOMAIN_ID="2"

# UDP handshake labels. Use lab-specific non-secret labels or random local values.
PAIRING_CODE="ROBOT_PAIRING_CODE"
ROBOT_NAME="turtlebot4"

# Laptop-side telemetry ports
YOLO_TELEMETRY_PORT=6610
QR_TELEMETRY_PORT=6611
REACTIVE_NAV_TELEMETRY_PORT=6612

# Optional YOLO model override
YOLO_SIGNAL_MODEL=""

# Laptop-side actionability gates for final-run candidate tuning.
YOLO_ACTION_CONF_THRESHOLD=0.30
YOLO_ACTION_MIN_AREA_RATIO=0.01
YOLO_ACTION_CENTER_X_MIN=0.03
YOLO_ACTION_CENTER_X_MAX=0.97
